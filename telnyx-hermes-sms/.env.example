# Required
TELNYX_API_KEY=KEY_YOUR_TELNYX_API_KEY
TELNYX_SMS_FROM_NUMBER=+15551234567

# Optional outbound/profile configuration
TELNYX_MESSAGING_PROFILE_ID=
TELNYX_SMS_API_BASE=https://api.telnyx.com/v2

# Optional webhook listener configuration
TELNYX_SMS_WEBHOOK_HOST=127.0.0.1
TELNYX_SMS_WEBHOOK_PORT=8087
TELNYX_SMS_WEBHOOK_PATH=/webhooks/telnyx/sms

# Webhook signature validation (recommended: leave enabled)
# Get your public key from https://portal.telnyx.com → Account Settings → Public Key
# or GET /v2/public_key
TELNYX_PUBLIC_KEY=
# Set to false only for local development without signature validation
TELNYX_SMS_REQUIRE_SIGNATURE=true
TELNYX_SMS_SIGNATURE_TOLERANCE=300

# Authorization / cron delivery
TELNYX_SMS_ALLOWED_USERS=+15551230001,+15551230002
TELNYX_SMS_ALLOW_ALL_USERS=false
TELNYX_SMS_HOME_CHANNEL=+15551230001

# Live tests: all four must be set to send a real SMS
TELNYX_SMS_TEST_TO=+15557654321
TELNYX_SMS_LIVE_TEST=0
