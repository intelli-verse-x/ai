      "risk_classes": {
        "read_only": "Discovery or inspection only. No account mutation or external side effect is expected.",
        "guarded_write": "Billed execution or account-scoped mutation may occur. Confirm intent before mutating state.",
        "live_write": "Can send traffic, move money, provision resources, or change regulated production state. Explicit approval is expected before execution."
      },
      "approval_expectations": {
        "none": "No extra approval is expected beyond normal caller authorization.",
        "confirm_before_mutation": "Obtain human or policy confirmation before any state-changing or billed execution.",
        "confirm_before_external_effect": "Obtain explicit human or policy approval before sending traffic, spending funds, or provisioning live resources."
      },
      "approval_paths": {
        "none_read_only": "Read-only discovery or inspection. Persist returned request identifiers for traceability when needed.",
        "confirm_intent_then_mutate": "Capture user or policy confirmation and preserve request-scoped identifiers before any billed or state-changing execution.",
        "explicit_approval_then_execute": "Require explicit operator approval, then retain the returned identifiers needed to review external effects, provisioning, or spend."
      },
      "memory_scopes": {
        "stateless": "The surface does not retain conversation state unless the caller supplies it.",
        "host_controlled": "Persistence, if any, is owned by Telnyx or the host system rather than the model runtime.",
        "customer_configured": "The customer configures the memory or conversation-retention behavior for this capability.",
        "app_scoped": "State is bounded to the MCP app or workflow contract rather than the full Telnyx account surface."
      },
      "model_behaviors": {
        "host_controlled": "No model behavior is exposed at this discovery layer, or execution is not model-driven.",
        "request_selected": "The caller chooses the model at request time.",
        "customer_configured": "The customer selects and configures the model during resource setup.",
        "app_defined": "Model behavior is constrained by the governed app or workflow surface."
      },
