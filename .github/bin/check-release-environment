#!/usr/bin/env bash
# Pre-release sanity checks. Run by release-doctor workflow on PRs to main.

set -eu

errors=()

# Read out the publish gate state without blocking PR validation. Publish jobs
# enforce the same gate in strict mode before any package publish step runs.
if ! GATE_READOUT="$(bash ./.github/bin/check-publish-gate --readout-only 2>&1)"; then
  errors+=("Publish gate readout failed unexpectedly: $GATE_READOUT")
else
  echo "Publish gate status: $GATE_READOUT"
fi

# Check no internal URLs leaked into publishable files
INTERNAL_HITS=$(grep -r "\.query\.prod\.telnyx\.io\|\.query\.dev\.telnyx\.io\|\.service\.consul\|\.internal\.telnyx" \
  tools/python/telnyx_agent_toolkit/ tools/typescript/src/ cli/src/ \
  --include="*.py" --include="*.ts" -l 2>/dev/null || true)

if [[ -n "$INTERNAL_HITS" ]]; then
  errors+=("Internal URLs found in publishable source files: $INTERNAL_HITS")
fi

# Check Python tool count matches TypeScript
PY_COUNT=$(python3 -c "
import sys; sys.path.insert(0, 'tools/python')
from telnyx_agent_toolkit.shared.constants import TOOL_DEFINITIONS
print(len(TOOL_DEFINITIONS))
" 2>/dev/null || echo "?")

TS_COUNT=$(node -e "
const fs = require('fs');
const c = fs.readFileSync('tools/typescript/src/shared/constants.ts','utf8');
const definitions = c.slice(c.indexOf('export const TOOL_DEFINITIONS'));
const m = definitions.match(/^  [a-z0-9_]+:\s*\{$/gm) || [];
console.log(m.length);
" 2>/dev/null || echo "?")

if [[ "$PY_COUNT" != "?" && "$TS_COUNT" != "?" && "$PY_COUNT" != "$TS_COUNT" ]]; then
  errors+=("Tool count mismatch: Python=$PY_COUNT TypeScript=$TS_COUNT")
fi

lenErrors=${#errors[@]}

if [[ $lenErrors -gt 0 ]]; then
  echo -e "Found the following errors in the release environment:\n"
  for error in "${errors[@]}"; do
    echo -e "- $error\n"
  done
  exit 1
fi

echo "The environment is ready to push releases!"
