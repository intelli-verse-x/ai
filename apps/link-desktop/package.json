{
  "name": "@telnyx/link-desktop",
  "productName": "Link",
  "version": "0.1.0",
  "private": true,
  "description": "Electron desktop MVP for Telnyx Link.",
  "type": "module",
  "main": "src/main/main.js",
  "scripts": {
    "predev": "npm --prefix ../../tools/link run build",
    "dev": "node scripts/dev.mjs",
    "prestart": "npm --prefix ../../tools/link run build && npm run build",
    "start": "LINK_DESKTOP_RENDERER=dist/renderer/index.html electron src/main/main.js",
    "restart": "node scripts/restart.mjs",
    "bundle:gog": "node scripts/install-gog-cli.mjs",
    "build": "vite build",
    "metadata:check": "scripts/check-service-metadata.sh",
    "whisper:build": "cd native/telnyx-whisper && bash Scripts/build-app.sh release",
    "whisper:test": "swift test --package-path native/telnyx-whisper",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test tests/*.test.ts",
    "pretest:e2e:google": "npm --prefix ../../tools/link run build && npm run build",
    "test:e2e:google": "tsx --test tests/e2e/google-workspace.test.ts",
    "pretest:e2e:inbox": "npm --prefix ../../tools/link run build && npm run build",
    "test:e2e:inbox": "tsx --test tests/e2e/google-inbox.test.ts",
    "test:e2e:phone": "tsx --test tests/e2e/phone-dialer.test.ts",
    "pretest:e2e:publisher": "npm --prefix ../../tools/link run build && npm run build",
    "test:e2e:publisher": "tsx --test tests/e2e/app-publisher.test.ts",
    "preview": "vite --host 127.0.0.1"
  },
  "dependencies": {
    "@tableau/embedding-api": "^3.15.1",
    "@telnyx/webrtc": "^2.27.1",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^39.2.7",
    "extract-zip": "^2.0.1",
    "lucide-react": "^0.561.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-is": "^19.2.7",
    "recharts": "^3.8.1",
    "vite": "^7.2.7"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "playwright": "^1.60.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "overrides": {
    "uuid": "^11.1.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
